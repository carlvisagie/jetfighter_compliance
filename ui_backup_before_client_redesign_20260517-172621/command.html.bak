<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JetFighter Compliance Command Center</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        :root {
            --bg-main: #f5f7fb;
            --bg-panel: #ffffff;
            --bg-header: #0f172a;
            --bg-ok: #16a34a;
            --bg-warn: #eab308;
            --bg-bad: #dc2626;
            --bg-info: #1d4ed8;
            --border-soft: #e5e7eb;
            --text-main: #0f172a;
            --text-muted: #6b7280;
            --text-inverse: #f9fafb;
            --accent: #2563eb;
            --shadow-soft: 0 10px 25px rgba(15, 23, 42, 0.08);
            --radius-lg: 14px;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: var(--bg-main);
            color: var(--text-main);
        }

        .page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            background: var(--bg-header);
            color: var(--text-inverse);
            padding: 16px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.5);
        }

        header .title-block {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        header h1 {
            margin: 0;
            font-size: 18px;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        header .subtitle {
            font-size: 13px;
            color: #9ca3af;
        }

        header .badges {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(148, 163, 184, 0.6);
        }

        .badge-dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #22c55e;
            box-shadow: 0 0 10px rgba(34, 197, 94, 0.7);
        }

        main {
            flex: 1;
            padding: 20px;
        }

        .grid {
            display: grid;
            grid-template-columns: 1.2fr 1.1fr 1.4fr;
            gap: 18px;
        }

        @media (max-width: 1100px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }

        .panel {
            background: var(--bg-panel);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-soft);
            padding: 14px 16px;
            border: 1px solid var(--border-soft);
            display: flex;
            flex-direction: column;
            min-height: 160px;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .panel-title {
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .panel-subtitle {
            font-size: 12px;
            color: var(--text-muted);
        }

        .pill {
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 999px;
            border: 1px solid var(--border-soft);
            color: var(--text-muted);
            background: #f9fafb;
        }

        .metrics-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
            margin-bottom: 8px;
        }

        .metric-card {
            border-radius: 10px;
            padding: 10px;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .metric-label {
            font-size: 11px;
            color: var(--text-muted);
        }

        .metric-value {
            font-size: 18px;
            font-weight: 600;
        }

        .metric-foot {
            font-size: 11px;
            color: var(--text-muted);
        }

        .status-tiles {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
            margin-top: 6px;
        }

        .status-tile {
            border-radius: 10px;
            padding: 8px;
            color: var(--text-inverse);
            font-size: 11px;
            line-height: 1.4;
        }

        .status-tile h4 {
            margin: 0 0 2px 0;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .status-ok {
            background: linear-gradient(135deg, #16a34a, #22c55e);
        }

        .status-warn {
            background: linear-gradient(135deg, #eab308, #f59e0b);
        }

        .status-bad {
            background: linear-gradient(135deg, #dc2626, #ef4444);
        }

        .status-info {
            background: linear-gradient(135deg, #1d4ed8, #3b82f6);
        }

        .status-tile .small {
            font-size: 10px;
            opacity: 0.9;
        }

        .list {
            flex: 1;
            border-radius: 10px;
            border: 1px solid #e5e7eb;
            background: #f9fafb;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .list-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 10px;
            background: #f3f4f6;
            border-bottom: 1px solid #e5e7eb;
            font-size: 11px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .list-body {
            flex: 1;
            overflow-y: auto;
            max-height: 280px;
        }

        .list-row {
            padding: 6px 10px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 12px;
            display: grid;
            grid-template-columns: 0.9fr 1.4fr 0.7fr;
            align-items: start;
            gap: 6px;
        }

        .list-row:last-child {
            border-bottom: none;
        }

        .list-row .label {
            font-weight: 500;
        }

        .list-row .meta {
            font-size: 11px;
            color: var(--text-muted);
        }

        .list-row .tag {
            justify-self: end;
            font-size: 11px;
            padding: 2px 7px;
            border-radius: 999px;
            border: 1px solid #e5e7eb;
            background: #ffffff;
            color: var(--text-muted);
        }

        .list-empty {
            padding: 10px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .footer-row {
            margin-top: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 11px;
            color: var(--text-muted);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 10px;
            font-size: 11px;
            border-radius: 999px;
            border: 1px solid #d1d5db;
            background: #ffffff;
            color: var(--text-main);
            cursor: pointer;
        }

        .btn-primary {
            border-color: var(--accent);
            background: var(--accent);
            color: var(--text-inverse);
        }

        .btn:active {
            transform: translateY(1px);
        }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 999px;
            background: #22c55e;
        }

        .dot.warn {
            background: #eab308;
        }

        .dot.bad {
            background: #dc2626;
        }

        .dot.muted {
            background: #9ca3af;
        }
    </style>
</head>
<body>
<div class="page">
    <header>
        <div class="title-block">
            <h1>JetFighter Compliance Command Center</h1>
            <div class="subtitle" id="header-subtitle">
                Consolidated health, events, and system status · Live
            </div>
        </div>
        <div class="badges">
            <div class="badge" id="badge-health">
                <span class="badge-dot" id="badge-health-dot"></span>
                <span id="badge-health-label">Core: Unknown</span>
            </div>
            <div class="badge">
                <span class="dot muted"></span>
                <span id="badge-refresh-label">Last refresh: —</span>
            </div>
            <button class="btn" onclick="window.location.href='/ui/control.html'">
                ← Back to Control Panel
            </button>
        </div>
    </header>

    <main>
        <div class="grid">
            <!-- SYSTEM HEALTH PANEL -->
            <section class="panel" id="panel-health">
                <div class="panel-header">
                    <div>
                        <div class="panel-title">System Health</div>
                        <div class="panel-subtitle">Backend · Tunnel · Public Host</div>
                    </div>
                    <span class="pill" id="pill-health">Status: Unknown</span>
                </div>

                <div class="metrics-row">
                    <div class="metric-card">
                        <div class="metric-label">Core Backend</div>
                        <div class="metric-value" id="metric-backend">—</div>
                        <div class="metric-foot" id="metric-backend-foot">/healthz</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Public Host</div>
                        <div class="metric-value" id="metric-host">—</div>
                        <div class="metric-foot" id="metric-host-foot">/status</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Recent Events</div>
                        <div class="metric-value" id="metric-events">—</div>
                        <div class="metric-foot" id="metric-events-foot">Last 24h (approx.)</div>
                    </div>
                </div>

                <div class="status-tiles" id="tiles-health">
                    <div class="status-tile status-info" id="tile-backend">
                        <h4>Backend</h4>
                        <div class="small" id="tile-backend-text">
                            Waiting for first health check…
                        </div>
                    </div>
                    <div class="status-tile status-info" id="tile-host">
                        <h4>Tunnel / Host</h4>
                        <div class="small" id="tile-host-text">
                            Waiting for /status response…
                        </div>
                    </div>
                    <div class="status-tile status-info" id="tile-webhook">
                        <h4>Webhooks</h4>
                        <div class="small" id="tile-webhook-text">
                            Use Webhook Verifier in Control Panel to run a live test.
                        </div>
                    </div>
                </div>

                <div class="footer-row">
                    <span>Health data auto-refreshes every 15 seconds.</span>
                    <button class="btn" onclick="manualRefresh()">Manual refresh</button>
                </div>
            </section>

            <!-- PROJECTS / COMPLETION PANEL (stubbed to extend later) -->
            <section class="panel" id="panel-projects">
                <div class="panel-header">
                    <div>
                        <div class="panel-title">Projects & Completion</div>
                        <div class="panel-subtitle">High-level completion overview</div>
                    </div>
                    <span class="pill">Autopilot view</span>
                </div>

                <div class="list">
                    <div class="list-header">
                        <span>Projects</span>
                        <span>Completion</span>
                    </div>
                    <div class="list-body" id="projects-body">
                        <div class="list-empty">
                            Project completion autopilot will read directly from your existing
                            project endpoints. When we plug it in, each project will show a
                            completion percentage and whether you are allowed to close it.
                        </div>
                    </div>
                </div>

                <div class="footer-row">
                    <span>This is the slot for the compliance autopilot brain.</span>
                    <button class="btn btn-primary" onclick="window.location.href='/ui/control.html'">
                        Open existing project tools
                    </button>
                </div>
            </section>

            <!-- EVENTS & LOGS PANEL -->
            <section class="panel" id="panel-events">
                <div class="panel-header">
                    <div>
                        <div class="panel-title">Events & Activity</div>
                        <div class="panel-subtitle">Most recent system events</div>
                    </div>
                    <span class="pill" id="pill-events">Loading…</span>
                </div>

                <div class="list">
                    <div class="list-header">
                        <span>Type · What</span>
                        <span>When</span>
                        <span>Status</span>
                    </div>
                    <div class="list-body" id="events-body">
                        <div class="list-empty">
                            Loading recent events…
                        </div>
                    </div>
                </div>

                <div class="footer-row">
                    <span>Data from /events/recent.</span>
                    <button class="btn" onclick="refreshEvents()">Refresh events</button>
                </div>
            </section>
        </div>
    </main>
</div>

<script>
    const REFRESH_INTERVAL_MS = 15000;

    function setBadgeHealth(stateText, level) {
        const badge = document.getElementById('badge-health');
        const dot = document.getElementById('badge-health-dot');
        const label = document.getElementById('badge-health-label');
        const pill = document.getElementById('pill-health');

        label.textContent = stateText;
        pill.textContent = 'Status: ' + stateText;

        dot.style.background = '#9ca3af';
        pill.style.background = '#f9fafb';
        pill.style.color = '#4b5563';

        if (level === 'ok') {
            dot.style.background = '#22c55e';
            pill.style.background = 'rgba(22,163,74,0.08)';
            pill.style.color = '#166534';
        } else if (level === 'warn') {
            dot.style.background = '#eab308';
            pill.style.background = 'rgba(234,179,8,0.12)';
            pill.style.color = '#854d0e';
        } else if (level === 'bad') {
            dot.style.background = '#dc2626';
            pill.style.background = 'rgba(220,38,38,0.10)';
            pill.style.color = '#7f1d1d';
        }
    }

    function setHeaderRefresh() {
        const label = document.getElementById('badge-refresh-label');
        const now = new Date();
        label.textContent = 'Last refresh: ' + now.toLocaleTimeString();
    }

    async function refreshHealth() {
        let backendOk = false;
        let hostOk = false;
        let eventsCount = null;

        // /healthz
        try {
            const res = await fetch('/healthz', {cache: 'no-store'});
            const data = await res.json();
            backendOk = data && data.status === 'ok';

            document.getElementById('metric-backend').textContent = backendOk ? 'OK' : 'Error';
            document.getElementById('metric-backend-foot').textContent = '/healthz';
            const backendTile = document.getElementById('tile-backend');
            const backendText = document.getElementById('tile-backend-text');
            backendTile.className = 'status-tile ' + (backendOk ? 'status-ok' : 'status-bad');
            backendText.textContent = backendOk
                ? 'Backend responding with status=ok.'
                : 'Backend did not respond with status=ok.';
        } catch (e) {
            document.getElementById('metric-backend').textContent = 'Error';
            const backendTile = document.getElementById('tile-backend');
            const backendText = document.getElementById('tile-backend-text');
            backendTile.className = 'status-tile status-bad';
            backendText.textContent = 'Failed to reach /healthz. Check FastAPI / Uvicorn.';
        }

        // /status
        try {
            const res = await fetch('/status', {cache: 'no-store'});
            if (res.ok) {
                hostOk = true;
                document.getElementById('metric-host').textContent = 'OK';
                document.getElementById('metric-host-foot').textContent = '/status';
                const hostTile = document.getElementById('tile-host');
                const hostText = document.getElementById('tile-host-text');
                hostTile.className = 'status-tile status-ok';
                hostText.textContent = 'Public host endpoint responding.';
            } else {
                document.getElementById('metric-host').textContent = 'Error';
                const hostTile = document.getElementById('tile-host');
                const hostText = document.getElementById('tile-host-text');
                hostTile.className = 'status-tile status-warn';
                hostText.textContent = 'Status endpoint reachable but not OK. HTTP ' + res.status + '.';
            }
        } catch (e) {
            document.getElementById('metric-host').textContent = 'Error';
            const hostTile = document.getElementById('tile-host');
            const hostText = document.getElementById('tile-host-text');
            hostTile.className = 'status-tile status-warn';
            hostText.textContent = 'Failed to fetch /status. Tunnel or route may be down.';
        }

        // /events/recent (just for approximate count)
        try {
            const res = await fetch('/events/recent', {cache: 'no-store'});
            if (res.ok) {
                const data = await res.json();
                if (Array.isArray(data)) {
                    eventsCount = data.length;
                    document.getElementById('metric-events').textContent = String(eventsCount);
                    document.getElementById('metric-events-foot').textContent =
                        'Recent events returned from /events/recent';
                }
            }
        } catch (e) {
            document.getElementById('metric-events').textContent = '—';
        }

        // Overall badge
        if (backendOk && hostOk) {
            setBadgeHealth('All Core OK', 'ok');
        } else if (backendOk || hostOk) {
            setBadgeHealth('Partial Degraded', 'warn');
        } else {
            setBadgeHealth('Core Down', 'bad');
        }

        setHeaderRefresh();
    }

    async function refreshEvents() {
        const body = document.getElementById('events-body');
        const pill = document.getElementById('pill-events');
        body.innerHTML = '<div class="list-empty">Loading recent events…</div>';
        pill.textContent = 'Loading…';

        try {
            const res = await fetch('/events/recent', {cache: 'no-store'});
            if (!res.ok) {
                body.innerHTML = '<div class="list-empty">Failed to load /events/recent (HTTP ' +
                    res.status + ').</div>';
                pill.textContent = 'Error';
                return;
            }
            const data = await res.json();
            if (!Array.isArray(data) || data.length === 0) {
                body.innerHTML = '<div class="list-empty">No recent events returned.</div>';
                pill.textContent = '0 events';
                return;
            }

            pill.textContent = data.length + ' events';
            body.innerHTML = '';
            data.slice(0, 30).forEach(ev => {
                const row = document.createElement('div');
                row.className = 'list-row';

                const label = document.createElement('div');
                label.className = 'label';
                label.textContent = ev.event_type || ev.type || 'EVENT';

                const meta = document.createElement('div');
                meta.className = 'meta';
                const what = ev.what || ev.message || ev.detail || '';
                meta.textContent = what;

                const when = document.createElement('div');
                when.className = 'meta';
                when.textContent = ev.when_utc || ev.when || ev.timestamp || '';

                const tag = document.createElement('div');
                tag.className = 'tag';
                tag.textContent = ev.status || 'logged';

                row.appendChild(label);
                row.appendChild(meta);
                row.appendChild(when);
                row.appendChild(tag);

                body.appendChild(row);
            });
        } catch (e) {
            body.innerHTML = '<div class="list-empty">Error while loading events. Check backend logs.</div>';
            pill.textContent = 'Error';
        }
    }

    function manualRefresh() {
        refreshHealth();
        refreshEvents();
    }

    // Initial load
    refreshHealth();
    refreshEvents();
    // Periodic refresh
    setInterval(refreshHealth, REFRESH_INTERVAL_MS);
</script>
</body>
</html>
